# Environment
.env
.env.*

# Dependencies
vendor/
composer.lock

# Uploaded files
public/uploads/products/*
!public/uploads/products/.gitkeep
writable/uploads/products/*
!writable/uploads/products/.gitkeep

# Debug toolbar - runtime debug data should never be committed
writable/debugbar/*.json

# OS
Thumbs.db
.DS_Store

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Logs
writable/logs/*
!writable/logs/.gitkeep

# Cache
writable/cache/*
!writable/cache/.gitkeep
writable/session/*
!writable/session/.gitkeep

# Temp
writable/temp/*
!writable/temp/.gitkeep

# Tests
writable/testing/*
!writable/testing/.gitkeep

# Build artifacts
build/
*.sql
/extract.php
/aiartstore.zip
