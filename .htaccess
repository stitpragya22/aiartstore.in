# ======================================================================
# SECURITY HARDENING FOR SHARED HOSTING
# ======================================================================

# Disable directory browsing
Options -Indexes

# Disable server signature
ServerSignature Off

# Protect against Apache mod_security errors
<IfModule mod_security.c>
	SecFilterEngine Off
	SecFilterScanPOST Off
</IfModule>

# ----------------------------------------------------------------------
# Rewrite engine
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
	Options +FollowSymlinks
	RewriteEngine On

	# RewriteBase: change to /subfolder/ if installed in a subfolder
	RewriteBase /aiartstore.in/

	# ==================================================================
	# BLOCK SENSITIVE PATHS
	# ==================================================================

	# Block access to app, system, vendor, writable, and tests directories
	RewriteRule ^(app|system|vendor|writable|tests)/ - [F,L]

	# Block all dotfiles (.env, .git, .htaccess, etc.)
	RewriteRule (^|/)\. - [F,L]

	# Block access to sensitive files
	RewriteRule ^(composer\.json|composer\.lock|package\.json|package-lock\.json|webpack\.mix\.js|.env|env)$ - [F,L]

	# Block access to build artifacts and deployment scripts
	RewriteRule ^(build/|spark|phpunit\.xml\.dist|preload\.php)$ - [F,L]

	# Block access to SQL dumps
	RewriteRule \.sql$ - [F,L]

	# ==================================================================
	# BLOCK COMMON EXPLOIT ATTEMPTS
	# ==================================================================

	# Block suspicious query strings
	RewriteCond %{QUERY_STRING} (base64_encode|base64_decode|mosConfig|phpinfo|eval\(|UNION\+SELECT|concat\(|gzinflate) [NC,OR]
	RewriteCond %{QUERY_STRING} (dbconfig|db_connect|cfg=|config=)(\s|$) [NC,OR]
	RewriteCond %{QUERY_STRING} (\<|%3C).*script.*(\>|%3E) [NC,OR]
	RewriteCond %{QUERY_STRING} (cmd|command|exec|system|passthru|shell_exec|proc_open|popen) [NC,OR]
	RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]) [OR]
	RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z])
	RewriteRule .* - [F,L]

	# Block suspicious user agents
	RewriteCond %{HTTP_USER_AGENT} (libwww-perl|wget|nikto|scaner|curl|phpMyAdmin|sqlmap|bmiddleware|nmap|webbandit|python-requests) [NC]
	RewriteRule .* - [F,L]

	# Block requests to common exploit targets
	RewriteCond %{REQUEST_URI} (wp-admin|wp-content|wp-includes|xmlrpc\.php|muieblackcat|phpmyadmin|myadmin|admin\.php|setup\.php) [NC]
	RewriteRule .* - [F,L]

	# ==================================================================
	# HTTP SECURITY HEADERS (via rewrite rules)
	# ==================================================================

	# Security headers (applied to all responses)
	<IfModule mod_headers.c>
		# Prevent MIME-type sniffing
		Header always set X-Content-Type-Options "nosniff"

		# Prevent clickjacking
		Header always set X-Frame-Options "SAMEORIGIN"

		# Enable XSS filter in browsers
		Header always set X-XSS-Protection "1; mode=block"

		# Referrer policy
		Header always set Referrer-Policy "strict-origin-when-cross-origin"

		# HSTS (only if HTTPS is enabled)
		# Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

		# Permissions policy (restrict browser features)
		Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
	</IfModule>

	# ==================================================================
	# PREVENT PHP EXECUTION IN UPLOADS
	# ==================================================================

	# Block PHP execution in upload directories
	RewriteCond %{REQUEST_URI} ^/uploads/.*\.php [NC]
	RewriteRule .* - [F,L]

	# ==================================================================
	# REDIRECT TO HTTPS (uncomment when SSL certificate is active)
	# ==================================================================
	# RewriteCond %{HTTPS} !=on
	# RewriteCond %{HTTP:X-Forwarded-Proto} !https
	# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

	# ==================================================================
	# CODEIGNITER REWRITE RULES
	# ==================================================================

	# Redirect www to non-www
	RewriteCond %{HTTPS} !=on
	RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
	RewriteRule ^ http://%1%{REQUEST_URI} [R=301,L]

	# Redirect trailing slashes
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteCond %{REQUEST_URI} (.+)/$
	RewriteRule ^ %1 [L,R=301]

	# Pass Authorization header
	RewriteCond %{HTTP:Authorization} .
	RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

	# Route to front controller
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^([\s\S]*)$ index.php/$1 [L,NC,QSA]
</IfModule>

<IfModule !mod_rewrite.c>
	ErrorDocument 404 index.php
</IfModule>

# ======================================================================
# PHP RUNTIME HARDENING (shared hosting compatible)
# ======================================================================
<IfModule mod_php.c>
	# Hide PHP version
	php_flag expose_php Off

	# Increase security for file uploads
	php_value upload_max_filesize 64M
	php_value post_max_size 64M
	php_value max_execution_time 120
	php_value max_input_time 120

	# Disable dangerous functions
	# php_value disable_functions exec,passthru,shell_exec,system,proc_open,popen,curl_exec,curl_multi_exec,parse_ini_file,show_source
</IfModule>

# ======================================================================
# BLOCK PHP EXECUTION IN UPLOAD DIRECTORIES
# ======================================================================
<IfModule mod_rewrite.c>
	RewriteRule ^(public/uploads|writable/uploads)/.*\.(php|phtml|php3|php4|php5|php7|php8)$ - [F,L]
</IfModule>

# ======================================================================
# MIME TYPES AND CACHING FOR STATIC ASSETS
# ======================================================================
<IfModule mod_expires.c>
	ExpiresActive On
	ExpiresByType image/jpg "access plus 1 year"
	ExpiresByType image/jpeg "access plus 1 year"
	ExpiresByType image/gif "access plus 1 year"
	ExpiresByType image/png "access plus 1 year"
	ExpiresByType image/webp "access plus 1 year"
	ExpiresByType image/svg+xml "access plus 1 year"
	ExpiresByType text/css "access plus 1 month"
	ExpiresByType text/javascript "access plus 1 month"
	ExpiresByType application/javascript "access plus 1 month"
	ExpiresByType application/font-woff "access plus 1 year"
	ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# Compress text files
<IfModule mod_deflate.c>
	AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
	AddOutputFilterByType DEFLATE application/javascript application/json application/xml
	AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>
