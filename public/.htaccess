# ======================================================================
# SECURITY HARDENING FOR SHARED HOSTING - PUBLIC DIRECTORY
# ======================================================================

# Disable directory browsing
Options -Indexes

# Disable server signature
ServerSignature Off

<IfModule mod_rewrite.c>
	Options +FollowSymlinks
	RewriteEngine On

	# ==================================================================
	# BLOCK SENSITIVE FILES
	# ==================================================================

	# Block all dotfiles
	RewriteRule (^|/)\. - [F,L]

	# Block access to sensitive files in public root
	RewriteRule ^(composer\.json|composer\.lock|package\.json|preload\.php|spark)$ - [F,L]

	# ==================================================================
	# HTTP SECURITY HEADERS
	# ==================================================================

	<IfModule mod_headers.c>
		# Prevent MIME-type sniffing
		Header always set X-Content-Type-Options "nosniff"

		# Prevent clickjacking
		Header always set X-Frame-Options "SAMEORIGIN"

		# Enable XSS filter
		Header always set X-XSS-Protection "1; mode=block"

		# Referrer policy
		Header always set Referrer-Policy "strict-origin-when-cross-origin"

		# Permissions policy
		Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"

		# Content Security Policy (adjust as needed)
		# Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://checkout.razorpay.com 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com; connect-src 'self'; frame-src 'self' https://checkout.razorpay.com"

		# HSTS (uncomment when HTTPS is active)
		# Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	</IfModule>

	# ==================================================================
	# BLOCK EXPLOIT ATTEMPTS
	# ==================================================================

	# Block suspicious query strings
	RewriteCond %{QUERY_STRING} (base64_encode|base64_decode|mosConfig|phpinfo|eval\(|UNION\+SELECT|concat\(|gzinflate) [NC,OR]
	RewriteCond %{QUERY_STRING} (\<|%3C).*script.*(\>|%3E) [NC,OR]
	RewriteCond %{QUERY_STRING} (cmd|command|exec|system|passthru|shell_exec|proc_open|popen) [NC,OR]
	RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]) [OR]
	RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z])
	RewriteRule .* - [F,L]

	# Block suspicious user agents
	RewriteCond %{HTTP_USER_AGENT} (libwww-perl|nikto|scaner|curl|phpMyAdmin|sqlmap|nmap) [NC]
	RewriteRule .* - [F,L]

	# ==================================================================
	# HTTPS REDIRECT (uncomment when SSL is active)
	# ==================================================================
	# RewriteCond %{HTTPS} !=on
	# RewriteCond %{HTTP:X-Forwarded-Proto} !https
	# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

	# ==================================================================
	# CODEIGNITER REWRITE RULES
	# ==================================================================

	# Redirect www to non-www
	RewriteCond %{HTTPS} !=on
	RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
	RewriteRule ^ http://%1%{REQUEST_URI} [R=301,L]

	# Redirect trailing slashes
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteCond %{REQUEST_URI} (.+)/$
	RewriteRule ^ %1 [L,R=301]

	# Pass Authorization header
	RewriteCond %{HTTP:Authorization} .
	RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

	# Route to front controller
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^([\s\S]*)$ index.php/$1 [L,NC,QSA]
</IfModule>

<IfModule !mod_rewrite.c>
	ErrorDocument 404 index.php
</IfModule>

# ======================================================================
# PHP RUNTIME HARDENING
# ======================================================================
<IfModule mod_php.c>
	php_flag expose_php Off
	php_value upload_max_filesize 64M
	php_value post_max_size 64M
	php_value max_execution_time 120
</IfModule>

# ======================================================================
# MIME TYPES AND CACHING
# ======================================================================
<IfModule mod_expires.c>
	ExpiresActive On
	ExpiresByType image/jpg "access plus 1 year"
	ExpiresByType image/jpeg "access plus 1 year"
	ExpiresByType image/gif "access plus 1 year"
	ExpiresByType image/png "access plus 1 year"
	ExpiresByType image/webp "access plus 1 year"
	ExpiresByType text/css "access plus 1 month"
	ExpiresByType text/javascript "access plus 1 month"
	ExpiresByType application/javascript "access plus 1 month"
</IfModule>

<IfModule mod_deflate.c>
	AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
	AddOutputFilterByType DEFLATE application/javascript application/json application/xml
</IfModule>

# ======================================================================
# BLOCK PHP EXECUTION IN UPLOADS
# ======================================================================
<IfModule mod_rewrite.c>
	RewriteRule ^uploads/.*\.(php|phtml|php3|php4|php5|php7|php8)$ - [F,L]
</IfModule>
